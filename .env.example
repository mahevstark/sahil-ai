# Required
DATABASE_URL=postgresql://user:password@localhost:5432/sahil_ai
OPENAI_API_KEY=sk-...

# Optional — Whisper model size: base | small | medium | large-v3
WHISPER_MODEL=large-v3

# Optional — Unique worker name (defaults to hostname)
# WORKER_ID=my-gaming-pc

# Optional — Logging
# LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
# LOG_FILE=worker.log     # leave empty for stdout only
